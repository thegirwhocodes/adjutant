# Adjutant runs entirely offline by default. These env vars are optional.

# --- LLM ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- STT ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu          # cpu | cuda | mps
WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32

# --- TTS ---
# If running Chatterbox locally on port 8001, leave as-is.
# If absent, Adjutant falls back to system TTS via pyttsx3.
CHATTERBOX_URL=http://localhost:8001

# --- RAG ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=.faiss_index
TOP_K=5

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
