# Adjutant runs entirely offline by default. These env vars are optional.

# --- LLM ---
OLLAMA_HOST=http://localhost:11434
# llama3.2:3b is the demo default — runs comfortably on 8GB laptops.
# For higher-quality RAG synthesis on a 16GB+ machine or rented GPU,
# pull and switch to llama3.1:8b. The prompts and JSON contracts are
# identical — only generation quality differs.
OLLAMA_MODEL=llama3.2:3b

# --- STT ---
# small.en is the sweet spot for English-only voice on a laptop CPU:
# 480MB on disk, ~1.2GB at runtime, ~6% WER on clean English.
# Bump to medium.en (~3GB) or large-v3 (~3.5GB) for noisier audio
# on a beefier machine.
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu          # cpu | cuda | mps
WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32

# --- TTS ---
# If running Chatterbox locally on port 8001, leave as-is.
# If absent, Adjutant falls back to system TTS via pyttsx3.
CHATTERBOX_URL=http://localhost:8001

# --- RAG ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=.faiss_index
TOP_K=5

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
